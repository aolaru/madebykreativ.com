{
  "ci": {
    "collect": {
      "staticDistDir": "dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/about/",
        "http://localhost/contact/",
        "http://localhost/news/"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.8
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.85
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ]
      }
    }
  }
}

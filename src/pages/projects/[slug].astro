---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import ProjectLogo from "../../components/ProjectLogo.astro";
import ProjectDirectoryCard from "../../components/ProjectDirectoryCard.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { buildUrl, createBreadcrumbSchema, createProjectSchema, isExternalHref, organizationSchema, projectDirectory, projectPath, statusDefinitions } from "../../data/site";

export function getStaticPaths() {
  return projectDirectory.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const projectHasExternalHref = isExternalHref(project.href);
const relatedProjects = projectDirectory
  .filter((item) => item.category === project.category && item.slug !== project.slug)
  .slice(0, 3);
const status = statusDefinitions.find((definition) => definition.label === project.status);
const newsEntries = await getCollection("news");
const relatedNews = project.relatedNews
  .map((slug) => newsEntries.find((entry) => entry.id.replace(/\.md$/, "") === slug))
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry))
  .map((entry) => ({
    ...entry,
    path: `/news/${entry.id.replace(/\.md$/, "")}/`
  }));
---

<BaseLayout
  title={`${project.label} | Made by Kreativ`}
  description={project.description}
  canonicalPath={projectPath(project.slug)}
  ogImage={buildUrl("/og-projects.svg")}
  ogImageAlt={`Made by Kreativ project profile card for ${project.label}.`}
  structuredData={[
    organizationSchema,
    createProjectSchema(project),
    createBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Projects", path: "/projects/" },
      { name: project.label, path: projectPath(project.slug) }
    ])
  ]}
>
  <HeroHeader
    current="projects"
    eyebrow={project.category}
    title={project.label}
    tagline={project.description}
  >
    <p slot="afterTagline" class="meta-note">{project.status}{status ? `: ${status.description}` : ""}</p>
  </HeroHeader>

  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Projects", href: "/projects/" }, { label: project.label }]} />

  <section class="content-card project-profile">
    <div class="project-profile-summary">
      <div>
        <ProjectLogo slug={project.slug} mark={project.logo.mark} />
      </div>
      <div>
        <p class="eyebrow">Project focus</p>
        <h2>{project.label}</h2>
        <p>{project.longDescription}</p>
      </div>
    </div>
    <ul class="focus-list">
      {project.focus.map((item) => <li>{item}</li>)}
    </ul>
    <p class="project-actions">
      {projectHasExternalHref && <a class="cta" href={project.href} target="_blank" rel="noopener">{project.cta}</a>}
      <a class="cta" href="/projects/">Back to Directory</a>
    </p>
  </section>

  {relatedNews.length > 0 && (
    <section class="content-card project-latest-update" aria-labelledby="project-latest-update-heading">
      <div>
        <p class="eyebrow">Latest project update</p>
        <h2 id="project-latest-update-heading">{relatedNews[0].data.title}</h2>
        <p>{relatedNews[0].data.description}</p>
      </div>
      <a class="button-cta button-cta-secondary" href={relatedNews[0].path}>Read {relatedNews[0].data.title}</a>
    </section>
  )}

  <section class="content-card project-detail-grid" aria-label="Project details">
    <article>
      <h2>What It Solves</h2>
      <p>{project.whatItSolves}</p>
    </article>
    <article>
      <h2>Who It Is For</h2>
      <p>{project.audience}</p>
    </article>
    <article>
      <h2>Current Status</h2>
      <p>{project.currentStatus}</p>
    </article>
  </section>

  <section class="content-card project-evidence" aria-labelledby="project-evidence-heading">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">Signals and next steps</p>
        <h2 id="project-evidence-heading">What to know now</h2>
      </div>
    </div>
    <div class="project-evidence-grid">
      <article>
        <h3>Current proof</h3>
        <ul class="clean-list">
          {project.proof.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article>
        <h3>Next steps</h3>
        <ul class="clean-list">
          {project.nextSteps.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  {relatedNews.length > 0 && (
    <section class="content-card related-updates" aria-labelledby="related-updates-heading">
      <div class="section-heading-row">
        <h2 id="related-updates-heading">Related Updates</h2>
        <a class="cta" href="/news/">All News</a>
      </div>
      <div class="latest-update-list">
        {relatedNews.map((entry) => (
          <article class="latest-update">
            <p class="news-date">{entry.data.dateLabel}</p>
            <h3><a href={entry.path}>{entry.data.title}</a></h3>
            <p>{entry.data.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {relatedProjects.length > 0 && (
    <section class="content-card related-projects" aria-labelledby="related-projects-heading">
      <h2 id="related-projects-heading">Related Projects</h2>
      <div class="project-directory-grid project-directory-grid-compact">
        {relatedProjects.map((item) => (
          <ProjectDirectoryCard
            href={projectPath(item.slug)}
            slug={item.slug}
            label={item.label}
            category={item.category}
            status={item.status}
            description={item.description}
            logo={item.logo}
            compact
          />
        ))}
      </div>
    </section>
  )}

  <SiteFooter />
</BaseLayout>

---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { buildUrl, createBreadcrumbSchema, createNewsArticleSchema, organizationSchema, site } from "../../data/site";

const newsPath = (id: string) => `/news/${id.replace(/\.md$/, "")}/`;

export async function getStaticPaths() {
  const entries = (await getCollection("news"))
    .sort((a, b) => b.data.sortDate.valueOf() - a.data.sortDate.valueOf());

  return entries.map((entry, index) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: {
      entry,
      newerEntry: entries[index - 1],
      olderEntry: entries[index + 1]
    }
  }));
}

const { entry, newerEntry, olderEntry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.replace(/\.md$/, "");
const canonicalPath = `/news/${slug}/`;
const publishedTime = entry.data.sortDate.toISOString();
const modifiedTime = new Date(`${site.lastUpdated}T00:00:00.000Z`).toISOString();
const articleSchema = createNewsArticleSchema({
  title: entry.data.title,
  description: entry.data.description,
  path: canonicalPath,
  datePublished: entry.data.sortDate,
  dateModified: new Date(modifiedTime)
});
---

<BaseLayout
  title={`${entry.data.title} | Made by Kreativ`}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogTitle={`${entry.data.title} | Made by Kreativ`}
  ogDescription={entry.data.description}
  ogImage={buildUrl("/og-news.svg")}
  ogImageAlt="Made by Kreativ news card for release notes and ecosystem updates."
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  structuredData={[
    organizationSchema,
    articleSchema,
    createBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "News", path: "/news/" },
      { name: entry.data.title, path: canonicalPath }
    ])
  ]}
>
  <HeroHeader
    current="news"
    eyebrow="News"
    title={entry.data.title}
    tagline={entry.data.description}
  >
    <p slot="afterTagline" class="meta-note">{entry.data.dateLabel}</p>
  </HeroHeader>

  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "News", href: "/news/" }, { label: entry.data.title }]} />

  <article class="content-card news-detail">
    <Content />
    <nav class="article-nav" aria-label="News article navigation">
      <a class="cta" href="/news/">Back to News</a>
      <div class="article-nav-pair">
        {newerEntry && <a class="cta" href={newsPath(newerEntry.id)}>Newer: {newerEntry.data.title}</a>}
        {olderEntry && <a class="cta" href={newsPath(olderEntry.id)}>Older: {olderEntry.data.title}</a>}
      </div>
    </nav>
  </article>

  <SiteFooter />
</BaseLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHeader from "../components/HeroHeader.astro";
import NewsEntry from "../components/NewsEntry.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { createNewsItemListSchema, organizationSchema } from "../data/site";

const toNewsPath = (id: string) => `/news/${id.replace(/\.md$/, "")}/`;

const newsEntries = (await getCollection("news"))
  .sort((a, b) => b.data.sortDate.valueOf() - a.data.sortDate.valueOf())
  .map((entry) => ({
    ...entry,
    path: toNewsPath(entry.id)
  }));

const latestNewsDate = newsEntries[0]?.data.sortDate;
const latestNewsLabel = latestNewsDate
  ? new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric", timeZone: "UTC" }).format(latestNewsDate)
  : "May 13, 2026";
---

<BaseLayout
  title="News | Made by Kreativ"
  description="Updates and notes from the Made by Kreativ ecosystem."
  canonicalPath="/news/"
  structuredData={[organizationSchema, createNewsItemListSchema(newsEntries)]}
>
  <HeroHeader
    current="news"
    eyebrow="Updates"
    title="News"
    tagline="News, release notes, and ecosystem updates."
  >
    <p slot="afterTagline" class="meta-note">Last updated: {latestNewsLabel}</p>
  </HeroHeader>

  <section class="news-index-list" aria-label="News updates">
    {newsEntries.map(({ data, path }) => (
      <NewsEntry date={data.dateLabel} title={data.title} description={data.description} href={path} />
    ))}
  </section>

  <section class="content-card news-follow-card">
    <h2>Follow Product Updates</h2>
    <p>Want release notes and ecosystem updates? Reach out directly and keep track of future product changes.</p>
    <p><a class="cta" href="mailto:info@madebykreativ.com?subject=Made%20by%20Kreativ%20Updates">Get Updates</a></p>
  </section>

  <SiteFooter />
</BaseLayout>

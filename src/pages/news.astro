---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHeader from "../components/HeroHeader.astro";
import NewsEntry from "../components/NewsEntry.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { organizationSchema } from "../data/site";

const newsEntries = await Promise.all(
  (await getCollection("news"))
    .sort((a, b) => b.data.sortDate.valueOf() - a.data.sortDate.valueOf())
    .map(async (entry) => ({
      ...entry,
      Content: (await render(entry)).Content
    }))
);
---

<BaseLayout
  title="News | Made by Kreativ"
  description="Updates and notes from the Made by Kreativ ecosystem."
  canonicalPath="/news/"
  structuredData={[organizationSchema]}
>
  <HeroHeader
    current="news"
    eyebrow="Updates"
    title="News"
    tagline="News, release notes, and ecosystem updates."
  >
    <p slot="afterTagline" class="meta-note">Last updated: May 10, 2026</p>
  </HeroHeader>

  {newsEntries.map(({ Content, data }) => (
    <NewsEntry date={data.dateLabel} title={data.title}>
      <Content />
    </NewsEntry>
  ))}

  <section class="content-card">
    <h2>Follow Product Updates</h2>
    <p>Want release notes and ecosystem updates? Reach out directly and keep track of future product changes.</p>
    <p><a class="cta" href="mailto:info@madebykreativ.com?subject=Made%20by%20Kreativ%20Updates">Get Updates</a></p>
  </section>

  <SiteFooter />
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import HeroHeader from "../components/HeroHeader.astro";
import ProjectLogo from "../components/ProjectLogo.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { buildUrl, createBreadcrumbSchema, createPageSchema, organizationSchema, projectCategories, projectDirectory, projectPath, statusDefinitions } from "../data/site";

const pageDescription = "Learn about the Made by Kreativ ecosystem, the practical product philosophy, and the independent tools, assets, and guides maintained by Andrei Olaru.";
---

<BaseLayout
  title="About | Made by Kreativ"
  description={pageDescription}
  canonicalPath="/about/"
  ogImage={buildUrl("/og-about.svg")}
  ogImageAlt="Made by Kreativ about page card for the independent product ecosystem."
  structuredData={[
    organizationSchema,
    createPageSchema({
      type: "AboutPage",
      name: "About | Made by Kreativ",
      description: pageDescription,
      path: "/about/"
    }),
    createBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "About", path: "/about/" }
    ])
  ]}
>
  <HeroHeader
    current="about"
    eyebrow="Our story"
    title="About Made by Kreativ"
    tagline="Independent digital products made for practical use, long-term reliability, and creative momentum."
  />

  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "About" }]} />

  <section class="content-card about-overview-card">
    <div class="section-heading-row">
      <div>
        <h2>What We Build</h2>
        <p>Made by Kreativ is the umbrella brand for focused digital properties: practical tools, creative resources, independent software, and adjacent projects built around useful workflows.</p>
      </div>
      <a class="cta" href="/projects/">Open Projects</a>
    </div>
    <div class="about-category-list">
      {projectCategories.map((category) => (
        <section class="about-category" aria-labelledby={`about-${category.label.toLowerCase().replaceAll(" ", "-")}`}>
          <h3 id={`about-${category.label.toLowerCase().replaceAll(" ", "-")}`}>{category.label}</h3>
          <p>{category.description}</p>
          <div class="about-project-list">
            {projectDirectory
              .filter((project) => project.category === category.label)
              .map((project) => (
                <a class="about-project-link" href={projectPath(project.slug)}>
                  <ProjectLogo slug={project.slug} mark={project.logo.mark} size="small" />
                  <span>
                    <strong>{project.label}</strong>
                    <span>{project.description}</span>
                  </span>
                </a>
              ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="content-card">
    <h2>Status Guide</h2>
    <dl class="status-legend status-legend-wide">
      {statusDefinitions.map((status) => (
        <div>
          <dt>{status.label}</dt>
          <dd>{status.description}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="content-card">
    <h2>How We Work</h2>
    <p>We prioritize clarity and shipping: small, opinionated products with useful defaults, simple interfaces, and predictable behavior.</p>
  </section>

  <section class="content-card">
    <h2>Built by Andrei Olaru</h2>
    <p>Made by KREATIV is independently built and maintained by Andrei Olaru, focused on practical creative tools that stay useful over time.</p>
    <p><a class="cta" href="/contact/">Reach out for collaborations</a></p>
  </section>

  <SiteFooter />
</BaseLayout>

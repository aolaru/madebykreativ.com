---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHeader from "../components/HeroHeader.astro";
import ProductCard from "../components/ProductCard.astro";
import SiteFooter from "../components/SiteFooter.astro";
import {
  ecosystemItemListSchema,
  organizationSchema,
  products,
  projectCategories,
  websiteSchema
} from "../data/site";

const latestNews = (await getCollection("news"))
  .sort((a, b) => b.data.sortDate.valueOf() - a.data.sortDate.valueOf())
  .slice(0, 3)
  .map((entry) => ({
    ...entry,
    path: `/news/${entry.id.replace(/\.md$/, "")}/`
  }));

const resourcePath = [
  {
    eyebrow: "Free starting point",
    title: "Your First Digital Product",
    description: "Choose one simple product idea with prompts, examples, validation steps, and fillable worksheets.",
    href: "/your-first-digital-product/",
    cta: "Download the free guide",
    isPrimary: true
  },
  {
    eyebrow: "Paid execution system",
    title: "The KREATIV AI Launch Toolkit",
    description: "Turn the chosen idea into a buyer-ready offer with launch prompts, worksheets, swipe copy, and checks.",
    href: "/ai-launch-toolkit/",
    cta: "View the toolkit",
    isPrimary: false
  }
];
---

<BaseLayout
  title="Made by Kreativ"
  description="Creative tools, curated assets, and utility software crafted by the Kreativ brand."
  canonicalPath="/"
  structuredData={[organizationSchema, websiteSchema, ecosystemItemListSchema]}
>
  <HeroHeader
    current="home"
    logoSrc="/favicon.svg"
    logoAlt="Kreativ brand mark"
    logoWidth={104}
    logoHeight={104}
    eyebrow="Independent digital studio"
    title="Made by Kreativ"
    tagline="Creative tools, curated assets, and utility software crafted to help you ship real projects."
  >
    <div slot="preface" class="launch-ribbon">
      <p><strong>Ecosystem update.</strong> Kreativ Tools is live, bringing image, video, PDF, and file utilities into the Made by Kreativ lineup.</p>
      <a class="cta" href="/news/">Read News</a>
    </div>
    <div slot="afterTagline" class="landing-actions hero-home-actions">
      <a class="button-cta button-cta-primary" href="/your-first-digital-product/">Start with the free guide</a>
      <a class="button-cta button-cta-secondary" href="/ai-launch-toolkit/">View the toolkit</a>
    </div>
  </HeroHeader>

  <div class="hero-bridge">
    <span class="hero-bridge-item">4 active properties</span>
    <span class="hero-bridge-item">8 KREATIV projects</span>
    <span class="hero-bridge-item">{projectCategories.length} project categories</span>
  </div>

  <section class="start-here" aria-labelledby="start-here-heading">
    <div class="section-intro">
      <p class="eyebrow">Start here</p>
      <h2 id="start-here-heading">Choose a product idea, then build the first version.</h2>
      <p>A practical free guide and a focused paid toolkit for creators who want to ship a small useful digital product without overbuilding.</p>
    </div>
    <div class="resource-path-grid">
      {resourcePath.map((resource) => (
        <article class:list={["resource-path-card", resource.isPrimary ? "resource-path-card-primary" : ""]}>
          <p class="eyebrow">{resource.eyebrow}</p>
          <h3>{resource.title}</h3>
          <p>{resource.description}</p>
          <a class={resource.isPrimary ? "button-cta button-cta-primary" : "button-cta button-cta-secondary"} href={resource.href}>{resource.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section-intro directory-intro">
    <p class="eyebrow">Core ecosystem</p>
    <h2>Ecosystem Directory</h2>
    <p>Four focused core properties for typography, sound, WordPress, and practical browser utilities.</p>
  </section>

  <section class="pillars">
    {products.map((product) => <ProductCard {...product} />)}
  </section>

  <section class="ecosystem-preview" aria-labelledby="ecosystem-preview-heading">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">Full project map</p>
        <h2 id="ecosystem-preview-heading">Explore the wider KREATIV ecosystem</h2>
        <p>The full directory covers core properties, roadmap projects, discovery work, and utility software in one filterable view.</p>
      </div>
      <a class="button-cta button-cta-secondary" href="/projects/">Open Projects</a>
    </div>
    <div class="ecosystem-preview-grid">
      {projectCategories.map((category) => (
        <article class="ecosystem-preview-item">
          <h3>{category.label}</h3>
          <p>{category.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-card latest-updates" aria-labelledby="latest-updates-heading">
    <div class="section-heading-row">
      <h2 id="latest-updates-heading">Latest Updates</h2>
      <a class="cta" href="/news/">All News</a>
    </div>
    <div class="latest-update-list">
      {latestNews.map((entry) => (
        <article class="latest-update">
          <p class="news-date">{entry.data.dateLabel}</p>
          <h3><a href={entry.path}>{entry.data.title}</a></h3>
          <p>{entry.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-card trust-strip">
    <div class="trust-copy">
      <p class="trust-kicker">Independent product ecosystem</p>
      <p>Built and maintained by Andrei Olaru.</p>
    </div>
    <p class="trust-action"><a class="cta" href="mailto:info@madebykreativ.com">info@madebykreativ.com</a></p>
  </section>

  <SiteFooter />
</BaseLayout>

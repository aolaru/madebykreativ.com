---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHeader from "../components/HeroHeader.astro";
import ProductCard from "../components/ProductCard.astro";
import SiteFooter from "../components/SiteFooter.astro";
import {
  ecosystemItemListSchema,
  organizationSchema,
  products,
  projectCategories,
  projectDirectory,
  projectPath,
  statusDefinitions,
  websiteSchema
} from "../data/site";

const latestNews = (await getCollection("news"))
  .sort((a, b) => b.data.sortDate.valueOf() - a.data.sortDate.valueOf())
  .slice(0, 3)
  .map((entry) => ({
    ...entry,
    path: `/news/${entry.id.replace(/\.md$/, "")}/`
  }));
---

<BaseLayout
  title="Made by Kreativ"
  description="Creative tools, curated assets, and utility software crafted by the Kreativ brand."
  canonicalPath="/"
  structuredData={[organizationSchema, websiteSchema, ecosystemItemListSchema]}
>
  <HeroHeader
    current="home"
    logoSrc="/favicon.svg"
    logoAlt="Kreativ brand mark"
    logoWidth={104}
    logoHeight={104}
    eyebrow="Independent digital studio"
    title="Made by Kreativ"
    tagline="Creative tools, curated assets, and utility software crafted to help you ship real projects."
  >
    <div slot="preface" class="launch-ribbon">
      <p><strong>Ecosystem update.</strong> Kreativ Tools is live, bringing image, video, PDF, and file utilities into the Made by Kreativ lineup.</p>
      <a class="cta" href="/news/">Read News</a>
    </div>
  </HeroHeader>

  <section class="hero-bridge" aria-label="Ecosystem overview">
    <span class="hero-bridge-item">4 active properties</span>
    <span class="hero-bridge-item">8 KREATIV projects</span>
    <span class="hero-bridge-item">{projectCategories.length} project categories</span>
  </section>

  <section class="content-card directory-intro">
    <h2>Ecosystem Directory</h2>
    <p>Four focused core properties, plus a growing set of KREATIV projects across typography, sound, WordPress, utilities, music, automotive, discovery, and signal tracking.</p>
  </section>

  <section class="pillars" aria-label="Kreativ products">
    {products.map((product) => <ProductCard {...product} />)}
  </section>

  <section class="content-card project-map" aria-labelledby="project-map-heading">
    <div class="section-heading-row">
      <div>
        <h2 id="project-map-heading">KREATIV Project Map</h2>
        <p>A categorized view of the complete ecosystem, from core product properties to focused independent projects.</p>
      </div>
      <a class="cta" href="/about/">About the ecosystem</a>
    </div>

    <div class="status-filter" aria-label="Filter projects by status">
      <button class="status-filter-button" type="button" data-project-filter="all" aria-pressed="true">All</button>
      {statusDefinitions.map((status) => (
        <button class="status-filter-button" type="button" data-project-filter={status.label} aria-pressed="false">{status.label}</button>
      ))}
    </div>

    <dl class="status-legend" aria-label="Project status definitions">
      {statusDefinitions.map((status) => (
        <div>
          <dt>{status.label}</dt>
          <dd>{status.description}</dd>
        </div>
      ))}
    </dl>

    <div class="project-category-grid">
      {projectCategories.map((category) => (
        <article class="project-category">
          <div class="category-heading">
            <h3>{category.label}</h3>
            <p>{category.description}</p>
          </div>
          <div class="category-project-list">
            {projectDirectory
              .filter((project) => project.category === category.label)
              .map((project) => (
                <a class="category-project" href={projectPath(project.slug)} data-project-status={project.status}>
                  <span class="pillar-status">{project.status}</span>
                  <strong>{project.label}</strong>
                  <span>{project.description}</span>
                </a>
              ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="content-card latest-updates" aria-labelledby="latest-updates-heading">
    <div class="section-heading-row">
      <h2 id="latest-updates-heading">Latest Updates</h2>
      <a class="cta" href="/news/">All News</a>
    </div>
    <div class="latest-update-list">
      {latestNews.map((entry) => (
        <article class="latest-update">
          <p class="news-date">{entry.data.dateLabel}</p>
          <h3><a href={entry.path}>{entry.data.title}</a></h3>
          <p>{entry.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-card trust-strip">
    <div class="trust-copy">
      <p class="trust-kicker">Independent product ecosystem</p>
      <p>Built and maintained by Andrei Olaru.</p>
    </div>
    <p class="trust-action"><a class="cta" href="mailto:info@madebykreativ.com">info@madebykreativ.com</a></p>
  </section>

  <SiteFooter />
</BaseLayout>

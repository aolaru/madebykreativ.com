---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHeader from "../components/HeroHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { contactIntents, ecosystemLinks, organizationSchema, site } from "../data/site";
---

<BaseLayout
  title="Contact | Made by Kreativ"
  description="Contact Made by Kreativ for partnership, product questions, and support."
  canonicalPath="/contact/"
  structuredData={[organizationSchema]}
>
  <HeroHeader
    current="contact"
    eyebrow="Get in touch"
    title="Contact"
    tagline="For partnerships, product questions, and support requests."
  />

  <section class="content-card">
    <h2>Email</h2>
    <p>Primary contact: <a class="cta" href={`mailto:${site.email}`}>{site.email}</a></p>
    <p>Use this address for support, partnerships, licensing questions, and product feedback across the Kreativ ecosystem.</p>
  </section>

  <section class="content-card contact-intents" aria-labelledby="contact-intents-heading">
    <h2 id="contact-intents-heading">What to Contact Us About</h2>
    <div class="contact-grid">
      {contactIntents.map((intent) => (
        <article class="contact-option">
          <h3>{intent.title}</h3>
          <p>{intent.description}</p>
          <a class="cta" href={`mailto:${site.email}?subject=${encodeURIComponent(intent.subject)}`}>Start Email</a>
        </article>
      ))}
    </div>
  </section>

  <section class="content-card">
    <h2>Where to Find Us</h2>
    <ul>
      <li><a class="cta" href={site.url} target="_blank" rel="noopener">madebykreativ.com</a></li>
      {ecosystemLinks.map((link) => (
        <li><a class="cta" href={link.href} target="_blank" rel="noopener">{new URL(link.href).hostname}</a></li>
      ))}
    </ul>
  </section>

  <SiteFooter />
</BaseLayout>

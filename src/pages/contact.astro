---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHeader from "../components/HeroHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { ecosystemLinks, organizationSchema, site } from "../data/site";
---

<BaseLayout
  title="Contact | Made by Kreativ"
  description="Contact Made by Kreativ for partnership, product questions, and support."
  canonicalPath="/contact/"
  structuredData={[organizationSchema]}
>
  <HeroHeader
    current="contact"
    eyebrow="Get in touch"
    title="Contact"
    tagline="For partnerships, product questions, and support requests."
  />

  <section class="content-card">
    <h2>Email</h2>
    <p>Primary contact: <a class="cta" href={`mailto:${site.email}`}>{site.email}</a></p>
  </section>

  <section class="content-card">
    <h2>Where to Find Us</h2>
    <ul>
      <li><a class="cta" href={site.url} target="_blank" rel="noopener">madebykreativ.com</a></li>
      {ecosystemLinks.map((link) => (
        <li><a class="cta" href={link.href} target="_blank" rel="noopener">{new URL(link.href).hostname}</a></li>
      ))}
    </ul>
  </section>

  <SiteFooter />
</BaseLayout>

---
import ProjectLogo from "./ProjectLogo.astro";
import { projectPath } from "../data/site";

interface Props {
  slug: string;
  href: string;
  product: string;
  status: string;
  title: string;
  description: string;
  cta: string;
  logo: {
    mark: string;
  };
}

const { slug, href, product, status, title, description, cta, logo } = Astro.props;
const detailHref = projectPath(slug);
---

<article class="pillar" data-product={product}>
  <span class="pillar-header">
    <ProjectLogo slug={slug} mark={logo.mark} />
    <span class="pillar-status">{status}</span>
  </span>
  <h2>{title}</h2>
  <p>{description}</p>
  <span class="pillar-actions">
    <a class="cta" href={detailHref}>Project details</a>
    <a class="cta" href={href} target="_blank" rel="noopener">{cta}</a>
  </span>
</article>

---
interface Props {
  href: string;
  product: string;
  status: string;
  title: string;
  description: string;
  cta: string;
}

const { href, product, status, title, description, cta } = Astro.props;
---

<a class="pillar" data-product={product} href={href} target="_blank" rel="noopener">
  <span class="pillar-status">{status}</span>
  <h2>{title}</h2>
  <p>{description}</p>
  <span class="cta">{cta}</span>
</a>

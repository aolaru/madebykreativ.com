---
import Icon from "./Icon.astro";

interface Props {
  current?: "home" | "projects" | "news" | "about" | "contact";
}

const { current } = Astro.props;
---

<nav class="site-nav" aria-label="Site navigation">
  <a class="site-nav-brand" href="/" aria-current={current === "home" ? "page" : undefined} aria-label="Made by Kreativ home">
    <img class="site-nav-brand-mark" src="/favicon.svg" width="32" height="32" alt="" />
    <span class="site-nav-brand-text">Made by Kreativ</span>
  </a>
  <div class="site-nav-links">
    <a class="site-nav-link" href="/projects/" aria-current={current === "projects" ? "page" : undefined}>Projects</a>
    <a class="site-nav-link" href="/news/" aria-current={current === "news" ? "page" : undefined}>News</a>
    <a class="site-nav-link" href="/about/" aria-current={current === "about" ? "page" : undefined}>About</a>
    <a class="site-nav-link" href="/contact/" aria-current={current === "contact" ? "page" : undefined}>Contact</a>
  </div>
  <div class="site-nav-actions" role="group" aria-label="Page actions">
    <button class="icon-button share-toggle" id="share-button" type="button" aria-label="Share this page" title="Share this page"><Icon name="share" /></button>
    <button class="icon-button theme-toggle" id="theme-toggle" type="button" aria-pressed="false" aria-label="Toggle dark mode"><Icon name="moon" /></button>
  </div>
</nav>

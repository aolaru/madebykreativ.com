---
import SiteNav from "./SiteNav.astro";

interface Props {
  current?: "home" | "books" | "projects" | "news" | "about" | "contact";
  logoSrc?: string;
  logoAlt?: string;
  logoWidth?: number;
  logoHeight?: number;
  showLogo?: boolean;
  eyebrow: string;
  title: string;
  tagline: string;
}

const {
  current,
  logoSrc = "/favicon.svg",
  logoAlt = "Kreativ brand mark",
  logoWidth = 104,
  logoHeight = 104,
  showLogo = false,
  eyebrow,
  title,
  tagline
} = Astro.props;
---

<header class="hero">
  <SiteNav current={current} />
  <slot name="preface" />
  {showLogo && <img class="brand-logo" src={logoSrc} width={logoWidth} height={logoHeight} alt={logoAlt} />}
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="tagline">{tagline}</p>
  <slot name="afterTagline" />
</header>
